# ===========================
# Supabase
# ===========================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================
# OpenAI
# ===========================
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ===========================
# Stripe
# ===========================
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# ===========================
# App
# ===========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
FREE_MONTHLY_LIMIT=10
PRO_MONTHLY_LIMIT=1000

# ===========================
# WhatsApp Provider
# Set to "meta" or "evolution". If unset, auto-detects from payload.
# ===========================
WHATSAPP_PROVIDER=meta

# ── Meta Cloud API (official WhatsApp Business API) ──────────────────────────
# Get these from https://developers.facebook.com/apps
META_WHATSAPP_TOKEN=your-permanent-access-token
META_PHONE_NUMBER_ID=your-phone-number-id
META_VERIFY_TOKEN=any-secret-string-you-choose

# ── Evolution API (open-source, WhatsApp Web) ────────────────────────────────
# Self-hosted: https://doc.evolution-api.com
EVOLUTION_API_URL=https://your-evolution-api-url.com
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE_ID=your-instance-name

# Demo WhatsApp number (optional — if set, landing page button links here)
NEXT_PUBLIC_WHATSAPP_DEMO_NUMBER=5511999999999
